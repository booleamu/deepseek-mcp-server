# ============ 认证方式（三选一） ============

# 方式一：官方 API Key（推荐，功能最全）
DEEPSEEK_API_KEY=sk-your-api-key-here

# 方式二：网页版 User Token（从浏览器 localStorage 获取）
# DEEPSEEK_USER_TOKEN=your-user-token-here

# 方式三：网页版账号密码登录
# DEEPSEEK_EMAIL=your-email@example.com
# DEEPSEEK_PASSWORD=your-password

# ============ 可选配置 ============

# API 基础地址（可选，默认 https://api.deepseek.com）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 网页版 API 基础地址（可选，默认 https://chat.deepseek.com/api/v0）
# DEEPSEEK_WEB_BASE_URL=https://chat.deepseek.com/api/v0

# 请求超时（可选，默认 30000ms）
DEEPSEEK_TIMEOUT=30000

# 最大重试次数（可选，默认 3）
DEEPSEEK_MAX_RETRIES=3
